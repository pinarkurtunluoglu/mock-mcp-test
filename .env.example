# ──────────────────────────────────────────────
# MCP Server Settings
# ──────────────────────────────────────────────
MCP_SERVER_NAME=dataverse-mcp
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ──────────────────────────────────────────────
# Dataverse / Azure AD Settings (Required)
# ──────────────────────────────────────────────
DATAVERSE_URL=https://orgXXXXXXXX.crm4.dynamics.com/
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=your_secret_here
TENANT_ID=00000000-0000-0000-0000-000000000000

# ──────────────────────────────────────────────
# Target Entity (change to point to a different table)
# ──────────────────────────────────────────────
ENTITY_SET_NAME=mserp_tryaiinventoryagingreportentities
ENTITY_LOGICAL_NAME=mserp_tryaiinventoryagingreportentity

# ──────────────────────────────────────────────
# Data Processing Limits
# ──────────────────────────────────────────────
MAX_PAGE_SIZE=500
MAX_TOTAL_RECORDS=5000
SUMMARY_MAX_TOKENS=2000

# Whitelist: Specific tables only (empty for all)
# Example: ALLOWED_TABLES=account,contact,lead
ALLOWED_TABLES=

LOG_LEVEL=INFO
