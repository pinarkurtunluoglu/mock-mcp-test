# ──────────────────────────────────────────────
# Azure AD / Entra ID Credentials
# ──────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ──────────────────────────────────────────────
# Dataverse Environment
# ──────────────────────────────────────────────
DATAVERSE_URL=https://your-org.crm.dynamics.com

# ──────────────────────────────────────────────
# MCP Server Settings
# ──────────────────────────────────────────────
MCP_SERVER_NAME=dataverse-mcp
# Transport: stdio | sse | streamable-http
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ──────────────────────────────────────────────
# Veri İşleme Limitleri
# ──────────────────────────────────────────────
MAX_PAGE_SIZE=500
MAX_TOTAL_RECORDS=5000
SUMMARY_MAX_TOKENS=2000

# Whitelist: Sadece belirli tablolara izin ver (boş bırakırsan hepsine izin verir)
# Örnek: ALLOWED_TABLES=accounts,contacts,mserp_salesorders
ALLOWED_TABLES=

LOG_LEVEL=INFO

